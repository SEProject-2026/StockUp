# --- Security ---
# Mandatory: Change this to a random string!
SECRET_KEY=change_me_please

# Standard JWT settings (Safe to keep as is)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Database ---
# Example for local development (Docker/Localhost)
# Format: postgresql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql://postgres:password@localhost:5432/stockup_db